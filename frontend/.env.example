# ── Frontend Environment Variables ─────────────────────────────────
# Copy to .env.local and fill in values

# Backend API base (must match FastAPI prefix /api)
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# Blockchain chain ID (31337 = Hardhat local, 1 = Ethereum mainnet)
NEXT_PUBLIC_CHAIN_ID=31337

# RPC shown when MetaMask adds the network automatically (run `npx hardhat node` for local)
NEXT_PUBLIC_CHAIN_RPC_URL=http://127.0.0.1:8545

# Optional: name in MetaMask (defaults to Hardhat Local for 31337)
# NEXT_PUBLIC_CHAIN_NAME=Hardhat Local

# Optional: block explorer (e.g. Sepolia) — omit for local Hardhat
# NEXT_PUBLIC_CHAIN_EXPLORER_URL=https://sepolia.etherscan.io

# Contract addresses (set after deploying with `npx hardhat run scripts/deploy.js`)
NEXT_PUBLIC_LOAN_CONTRACT_ADDRESS=
NEXT_PUBLIC_VAULT_CONTRACT_ADDRESS=
NEXT_PUBLIC_NFT_CONTRACT_ADDRESS=
NEXT_PUBLIC_RATE_MODEL_ADDRESS=
